# === B4Y SuperAPP – Umgebungsvariablen ===
# Diese Datei dokumentiert die benötigten Variablen. NIEMALS echte Secrets committen!
# In Vercel werden diese pro Umgebung gesetzt: Production / Preview / Development.

# Öffentlicher Supabase-Zugang (sicher fürs Frontend, durch RLS geschützt)
VITE_SUPABASE_URL=https://DEINE-PROJEKT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx_oder_anon_key

# Produkt-/Branding-Layer (white-label, mandantenneutral). Ohne Setzung gelten die Defaults.
#   VITE_APP_NAME = Produktname (Default: "B4Y SuperAPP"; für Kunden z.B. "Handwerk SuperAPP")
#   VITE_APP_URL  = öffentliche App-Domain (Default: https://b4y-superapp.app)
# Firmenname/Logo/Farben/PDF-Firmendaten kommen pro Mandant aus den Firmeneinstellungen.
VITE_APP_NAME=B4Y SuperAPP
VITE_APP_URL=https://b4y-superapp.app

# ACHTUNG: Der SERVICE-ROLE-KEY gehört NIEMALS ins Frontend / in VITE_*-Variablen!
# Er darf ausschließlich serverseitig (z. B. Edge Functions, GitHub Secrets) verwendet werden.
# SUPABASE_SERVICE_ROLE_KEY=<nur serverseitig, niemals hier>

# Lokale Supabase-CLI fuer Migrationen aus VS Code/Claude Code.
# Diese Werte NIEMALS committen. Lokal in .env.supabase.local oder .env.local setzen.
# SUPABASE_PROJECT_REF=pqwcpgmsutpbuvdzslbc
# SUPABASE_DB_PASSWORD=<Datenbank-Passwort aus Supabase Dashboard>
# SUPABASE_ACCESS_TOKEN=<optional: Supabase Personal Access Token fuer frische Maschinen ohne supabase login>
